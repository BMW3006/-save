# Supabase Configuration (Optional)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Groq AI API Key (Required for Groq Chat)
GROQ_API_KEY=your_groq_api_key

# Music API Configuration
# The music download feature uses davidcyriltech API
# https://apis.davidcyriltech.my.id/endpoints/download/

# Note: Music data is stored in localStorage on the client-side
# No server-side configuration is required for music feature
